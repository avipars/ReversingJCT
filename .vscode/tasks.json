{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ASM",
            "type": "shell",
            "command": "fasm",
            "args": [
                "${file}",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always", 
                "panel": "shared",
                "showReuseMessage": false
            },
            "options": {
                "cwd": "${fileDirname}"
            }
        },
        {
            "label": "Build & Run ASM",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "fasm \"${file}\" \"${fileDirname}\\${fileBasenameNoExtension}.exe\" && \"${fileDirname}\\${fileBasenameNoExtension}.exe\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
             "presentation": {
                "reveal": "always", 
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        },
        {
            "type": "shell",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
             "presentation": {
                "reveal": "always", 
                "panel": "shared",
                "showReuseMessage": false
            },
            "detail": "Task generated by Debugger."
        },
    ]
}